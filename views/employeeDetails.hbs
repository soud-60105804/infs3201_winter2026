<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Employee Details</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <h1>Employee Details</h1>

    <p><b>ID:</b> {{employee.employeeId}}</p>
    <p><b>Name:</b> {{employee.name}}</p>
    <p><b>Phone:</b> {{employee.phone}}</p>

    <p>
        <a href="/employees/{{employee.employeeId}}/edit">Edit Details</a> |
        <a href="/">Back</a>
    </p>

    <h2>Shifts</h2>

    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Start</th>
                <th>End</th>
            </tr>
        </thead>
        <tbody>
            {{#each rows}}
                <tr>
                    <td>{{this.date}}</td>

                    {{#if this.isBeforeNoon}}
                        <td class="beforeNoon">{{this.startTime}}</td>
                        <td class="beforeNoon">{{this.endTime}}</td>
                    {{else}}
                        <td>{{this.startTime}}</td>
                        <td>{{this.endTime}}</td>
                    {{/if}}
                </tr>
            {{/each}}
        </tbody>
    </table>
</body>
</html>