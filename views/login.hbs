<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Login</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <h1>Login</h1>

    {{#if message}}
        <p>{{message}}</p>
    {{/if}}

    <form method="post" action="/login">
        <div>
            <label>Username</label>
            <input name="username">
        </div>

        <div>
            <label>Password</label>
            <input type="password" name="password">
        </div>

        <button type="submit">Login</button>
    </form>
</body>
</html>