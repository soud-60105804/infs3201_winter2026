<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Edit Employee</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <h1>Edit Employee</h1>

    <p><a href="/employees/{{employee.employeeId}}">Back</a></p>

    <form method="post" action="/employees/{{employee.employeeId}}/edit">
        <div>
            <label>Name</label>
            <input name="name" value="{{employee.name}}">
        </div>

        <div>
            <label>Phone</label>
            <input name="phone" value="{{employee.phone}}">
        </div>

        <button type="submit">Save</button>
    </form>
</body>
</html>